MONGODB_URI=mongodb://localhost:27017/chatapp
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# WebSocket / Socket.io Deployment Config
# Set to the URL of the hosted socket server when deploying to Vercel
NEXT_PUBLIC_SOCKET_SERVER_URL=
# Set to 'true' on the hosted socket server to run in lightweight socket-only mode
SOCKET_ONLY=
